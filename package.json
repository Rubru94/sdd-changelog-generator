{
  "name": "changelog-generator",
  "version": "0.1.0",
  "description": "Changelog Generator — CLI tool that generates changelogs from conventional commits, built with SDD",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:time": "tsx src/index.ts --date-format date-time --from HEAD~10",
    "build": "tsc",
    "package": "npm run build && mkdir -p pkg && pkg . --out-dir pkg --targets node18-linux-x64,node18-win-x64,node18-macos-x64",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "bin": {
    "changelog-generator": "./dist/index.js"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@yao-pkg/pkg": "^6.14.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.19.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
