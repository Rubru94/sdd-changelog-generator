{
  "name": "changelog-generator",
  "version": "0.1.0",
  "description": "Changelog Generator — CLI tool that generates changelogs from conventional commits, built with SDD",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "@types/node": "^22.12.0",
    "vitest": "^3.0.5",
    "eslint": "^9.19.0",
    "@typescript-eslint/parser": "^8.23.0",
    "@typescript-eslint/eslint-plugin": "^8.23.0",
    "prettier": "^3.4.2"
  }
}
